---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

// Cargos y Estructura de la Mesa Directiva
const mesaDirectiva = [
    {
        cargo: "Presidencia",
        nombre: "Laura Mlynarz Greibe",
        desc: "Representación política oficial de la federación. Conduce la postura pública y lidera las relaciones institucionales dentro y fuera del campus universitario.",
        color: "#981626"
    },
    {
        cargo: "Vicepresidencia",
        nombre: "Monserrat Lagos",
        desc: "Apoyo a la coordinación general de la Mesa Directiva, subrogancia de la presidencia y vinculación directa con los proyectos territoriales.",
        color: "#9C4AAF"
    },
    {
        cargo: "Secretaría General",
        nombre: "Javier Concha",
        desc: "Encargada del flujo interno de la federación. Redacción de actas, coordinación de los plenos y enlace oficial con los Centros Federados.",
        color: "#FCB020"
    },
    {
        cargo: "Secretaría de Finanzas",
        nombre: "Isidora Velasquez",
        desc: "Gestión y administración del presupuesto federativo. Asegura la transparencia, rendición de cuentas periódica y financiamiento de proyectos de base.",
        color: "#1E5E52"
    },
        {
        cargo: "Secretaría de Bienestar",
        nombre: "Jesús Malebran",
        desc: "Gestión y administración del presupuesto federativo. Asegura la transparencia, rendición de cuentas periódica y financiamiento de proyectos de base.",
        color: "#DF1F3C"
    },
    {
        cargo: "Secretaría de Bienestar",
        nombre: "Jesús Malebran",
        desc: "Gestión y administración del presupuesto federativo. Asegura la transparencia, rendición de cuentas periódica y financiamiento de proyectos de base.",
        color: "#ff0000"
    },
    {
        cargo: "Secretaría de Comunicaciones",
        nombre: "[Nombre del Secretario/a de Comunicaciones por definir]",
        desc: "Responsable de la difusión oficial de la FECh, coordinación de redes sociales, relación con la prensa y diseño de campañas informativas universitarias.",
        color: "#111"
    }
];
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <BaseHead title={`Mesa Directiva | ${SITE_TITLE}`} description="Mesa Directiva oficial de la Federación de Estudiantes de la Universidad de Chile" />
        <style>
            :global(body) {
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 1200px;
                margin: 0 auto;
                padding: clamp(2rem, 8vw, 4rem) 5%;
                box-sizing: border-box;
            }

            /* Títulos */
            h2 {
                font-family: 'creato', sans-serif;
                font-size: clamp(2.2rem, 7vw, 4.2rem);
                text-transform: uppercase;
                line-height: 0.85;
                margin-bottom: 2rem;
                color: #000;
            }

            .subtitle-kicker {
                font-family: monospace;
                font-size: 0.85rem;
                text-transform: uppercase;
                color: #666;
                letter-spacing: 0.1em;
                margin-bottom: 0.5rem;
                display: block;
            }

            .manifesto-box {
                border-left: 10px solid #000;
                padding: clamp(1.5rem, 4vw, 2.5rem);
                background: #f4f4f4;
                margin-bottom: 4rem;
                font-family: monospace;
                font-size: 1.15rem;
                border-top: 2px solid #111;
                border-right: 2px solid #111;
                border-bottom: 2px solid #111;
                box-shadow: 4px 4px 0px #111;
                border-radius: 4px;
            }

            .manifesto-box p {
                margin: 0;
                line-height: 1.6;
            }

            /* Cuadrícula de Cargos */
            .mesa-grid {
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: 2rem;
                margin-bottom: 5rem;
            }

            .mesa-card {
                grid-column: span 6;
                padding: clamp(2rem, 5vw, 3rem);
                color: #fff;
                border: 2px solid #111;
                border-radius: 8px;
                box-shadow: 6px 6px 0px #111;
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                display: flex;
                flex-direction: column;
                min-height: 280px;
            }

            .mesa-card:hover {
                transform: translate(-3px, -3px);
                box-shadow: 8px 8px 0px #ff0000;
                border-color: #ff0000;
            }

            .mesa-card--full {
                grid-column: span 12;
            }

            .mesa-card .cargo {
                font-family: 'creato', sans-serif;
                font-size: 1.1rem;
                border-bottom: 2px solid #ff0000;
                display: inline-block;
                margin-bottom: 1.5rem;
                width: fit-content;
                letter-spacing: 0.05em;
            }

            .mesa-card:hover .cargo {
                border-color: #fff;
            }

            .mesa-card .nombre {
                font-family: 'lora', sans-serif;
                font-size: 2rem;
                font-weight: 900;
                display: block;
                margin-bottom: 1rem;
                text-transform: uppercase;
                line-height: 1.1;
            }

            .mesa-card p {
                opacity: 0.9;
                font-size: 0.92rem;
                line-height: 1.6;
                margin: 0;
                flex-grow: 1;
            }

            /* Sección Estatutos / Objetivos */
            .vision-section {
                border-top: 0.45rem solid #111;
                padding-top: 2rem;
                margin-top: 4rem;
            }

            .vision-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 3rem;
                margin-top: 2rem;
            }

            .vision-block h3 {
                font-family: 'creato', sans-serif;
                font-size: 1.6rem;
                text-transform: uppercase;
                color: #ff0000;
                margin-bottom: 1rem;
            }

            .vision-block p {
                font-size: 0.95rem;
                line-height: 1.6;
                color: #333;
            }

            /* Ajustes Responsivos */
            @media (max-width: 820px) {
                .mesa-card {
                    grid-column: span 12;
                    min-height: auto;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <header>
                <span class="subtitle-kicker">Federación de Estudiantes de la Universidad de Chile</span>
                <h2>Mesa Directiva</h2>
                
                <div class="manifesto-box">
                    <p><strong>[LEMA O CONSIGNA DE LA GESTIÓN ACTUAL]:</strong> "Por una federación construida desde las bases, activa en las luchas sociales y comprometida con el desarrollo de una educación pública y democrática al servicio del pueblo."</p>
                </div>
            </header>

            <!-- GRILLA DE INTEGRANTES DE LA MESA DIRECTIVA -->
            <section class="mesa-grid">
                {mesaDirectiva.map((item, idx) => (
                    <div class={`mesa-card ${idx === 0 ? 'mesa-card--full' : ''}`} style={`background: ${item.color};`}>
                        <span class="cargo">{item.cargo}</span>
                        <span class="nombre">{item.nombre}</span>
                        <p>{item.desc}</p>
                    </div>
                ))}
            </section>

            <!-- OBJETIVOS GENERALES DE LA GESTIÓN -->
            <section class="vision-section">
                <h2>Líneas de Trabajo Generales</h2>
                <div class="vision-grid">
                    <div class="vision-block">
                        <h3>Democratización</h3>
                        <p>[Insertar aquí la planificación estratégica sobre la democratización institucional y la articulación orgánica del estudiantado. Espacio para redactar objetivos de base y reforma estatutaria.]</p>
                    </div>
                    <div class="vision-block">
                        <h3>Bienestar Estudiantil</h3>
                        <p>[Insertar aquí las propuestas y líneas de acción referidas a la salud mental, becas de mantención, alimentación Junaeb y calidad de vida en los distintos campus universitarios.]</p>
                    </div>
                    <div class="vision-block">
                        <h3>Vinculación Territorial</h3>
                        <p>[Espacio asignado para describir la proyección estudiantil hacia el medio social, el trabajo voluntario, la articulación con organizaciones vecinales y de trabajadores.]</p>
                    </div>
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>
