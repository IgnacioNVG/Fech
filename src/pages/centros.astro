---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

// Obtener los Centros de Estudiantes Federados dinámicamente
const centrosCollection = await getCollection('centros');
const centrosFederados = centrosCollection.map(c => ({
    id: c.id,
    sigla: c.data.sigla,
    nombre: c.data.nombre,
    facultad: c.data.facultad,
    campus: c.data.campus,
    color: c.data.color,
    link: `/centros/${c.id}`
})).sort((a, b) => a.nombre.localeCompare(b.nombre));

// Campus únicos para filtrado
const campusList = [...new Set(centrosFederados.map(c => c.campus))];
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <BaseHead title={`Centros Federados | ${SITE_TITLE}`} description="Directorio oficial de los Centros de Estudiantes Federados de la FECh" />
        <style>
            :global(body) {
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 1200px;
                margin: 0 auto;
                padding: clamp(2rem, 8vw, 4rem) 5%;
                box-sizing: border-box;
            }

            /* Títulos */
            h2 {
                font-family: 'Sifonn', sans-serif;
                font-size: clamp(2.2rem, 7vw, 4rem);
                text-transform: uppercase;
                line-height: 0.85;
                margin-bottom: 2rem;
                color: #000;
            }

            .subtitle-kicker {
                font-family: monospace;
                font-size: 0.85rem;
                text-transform: uppercase;
                color: #666;
                letter-spacing: 0.1em;
                margin-bottom: 0.5rem;
                display: block;
            }

            .intro-box {
                border-left: 10px solid #000;
                padding: clamp(1.5rem, 4vw, 2rem);
                background: #f4f4f4;
                margin-bottom: 3rem;
                font-family: monospace;
                font-size: 1.1rem;
                border-top: 2px solid #111;
                border-right: 2px solid #111;
                border-bottom: 2px solid #111;
                box-shadow: 4px 4px 0px #111;
                border-radius: 4px;
            }

            /* Filtros de Campus */
            .filter-band {
                display: flex;
                flex-wrap: wrap;
                gap: 0.75rem;
                margin-bottom: 3rem;
                border-bottom: 2px solid #111;
                padding-bottom: 1.5rem;
            }

            .filter-btn {
                background: #fff;
                border: 2px solid #111;
                padding: 0.45rem 1rem;
                font-family: monospace;
                font-size: 0.75rem;
                font-weight: bold;
                text-transform: uppercase;
                cursor: pointer;
                border-radius: 4px;
                transition: all 0.2s ease;
            }

            .filter-btn.active, .filter-btn:hover {
                background: #ff0000;
                color: #fff;
                border-color: #ff0000;
                transform: translateY(-2px);
                box-shadow: 2px 2px 0px #111;
            }

            /* Grilla Brutalista de Centros */
            .centros-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                gap: 2.2rem;
            }

            .centro-card {
                background: #fff;
                border: 2px solid #111;
                border-radius: 8px;
                box-shadow: 4px 4px 0px #111;
                padding: 2rem;
                text-decoration: none;
                color: inherit;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                min-height: 220px;
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

            .centro-card.hidden {
                display: none;
            }

            .centro-card:hover {
                transform: translate(-4px, -4px);
                box-shadow: 6px 6px 0px var(--hover-color) !important;
                border-color: var(--hover-color) !important;
            }

            .centro-badge {
                font-family: 'Sifonn', sans-serif;
                font-size: 1.8rem;
                text-transform: uppercase;
                margin-bottom: 1rem;
                display: inline-block;
                width: fit-content;
                padding: 0.15rem 0.6rem;
                color: #fff;
                border-radius: 4px;
                border: 2px solid #111;
                box-shadow: 2px 2px 0px #111;
            }

            .centro-card h3 {
                font-family: 'lora', sans-serif;
                font-weight: 800;
                font-size: 1rem;
                margin: 0 0 0.5rem 0;
                color: #111;
                line-height: 1.25;
            }

            .centro-meta {
                font-size: 0.82rem;
                color: #666;
                margin-bottom: 1rem;
            }

            .centro-campus {
                font-family: monospace;
                font-size: 0.72rem;
                text-transform: uppercase;
                background: #eee;
                color: #333;
                padding: 0.18rem 0.45rem;
                width: fit-content;
                margin-top: auto;
                border-radius: 2px;
            }

            /* Responsive */
            @media (max-width: 640px) {
                .centros-grid {
                    grid-template-columns: 1fr;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <header>
                <span class="subtitle-kicker">Organización Estudiantil de Base</span>
                <h2>Centros Federados</h2>
                <div class="intro-box">
                    <p>CONGRESO E INTEGRACIÓN: Directorio de los distintos Centros de Estudiantes Federados (CEEs) de la Universidad de Chile. Acceso directo a sus canales institucionales y actas de representación local.</p>
                </div>
            </header>

            <!-- FILTROS POR CAMPUS -->
            <div class="filter-band">
                <button class="filter-btn active" data-campus="all">Todos los Campus</button>
                {campusList.map((campus) => (
                    <button class="filter-btn" data-campus={campus}>{campus}</button>
                ))}
            </div>

            <!-- GRILLA DE CENTROS DE ESTUDIANTES -->
            <div class="centros-grid" id="centros-grid">
                {centrosFederados.map((centro) => (
                    <a
                        href={centro.link}
                        class="centro-card"
                        data-campus={centro.campus}
                        style={`--hover-color: ${centro.color};`}
                    >
                        <div>
                            <span class="centro-badge" style={`background: ${centro.color};`}>
                                {centro.sigla}
                            </span>
                            <h3>{centro.nombre}</h3>
                            <p class="centro-meta">{centro.facultad}</p>
                        </div>
                        <span class="centro-campus">{centro.campus}</span>
                    </a>
                ))}
            </div>
        </main>
        <Footer />

        <script>
            function initCampusFilters() {
                const filterButtons = document.querySelectorAll('.filter-btn');
                const cards = document.querySelectorAll('.centro-card');

                filterButtons.forEach(btn => {
                    btn.addEventListener('click', () => {
                        filterButtons.forEach(b => b.classList.remove('active'));
                        btn.classList.add('active');

                        const campusFilter = btn.getAttribute('data-campus');

                        cards.forEach(card => {
                            const cardCampus = card.getAttribute('data-campus');
                            if (campusFilter === 'all' || cardCampus === campusFilter) {
                                card.classList.remove('hidden');
                            } else {
                                card.classList.add('hidden');
                            }
                        });
                    });
                });
            }

            // Run on initial load and on every page transition swap
            document.addEventListener('astro:page-load', initCampusFilters);
        </script>
    </body>
</html>

