---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_TITLE } from '../../../consts';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
    const publicaciones = await getCollection('publicaciones');
    return publicaciones.map(pub => ({
        params: { id: pub.data.centro.toLowerCase(), slug: pub.id },
        props: { pub },
    }));
}

const { pub } = Astro.props;
const { Content } = await render(pub);

// Obtener los datos del centro asociado para el color y el nombre
const centro = await getEntry('centros', pub.data.centro.toLowerCase());
const centroColor = centro ? centro.data.color : '#111';
const centroNombre = centro ? centro.data.nombre : 'Centro Federado';
const centroSigla = centro ? centro.data.sigla : 'CEE';
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <BaseHead title={`${pub.data.title} | ${centroSigla} | ${SITE_TITLE}`} description={pub.data.description} />
        <style define:vars={{ "centro-color": centroColor }}>
            :global(body) {
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 800px;
                margin: 0 auto;
                padding: clamp(2rem, 8vw, 4rem) 5%;
                box-sizing: border-box;
            }

            .back-link {
                display: inline-block;
                font-family: monospace;
                font-weight: bold;
                text-transform: uppercase;
                color: #111;
                text-decoration: none;
                margin-bottom: 2rem;
                border-bottom: 2px solid #111;
                padding-bottom: 2px;
                transition: all 0.2s ease;
                width: fit-content;
            }

            .back-link:hover {
                color: var(--centro-color);
                border-color: var(--centro-color);
                transform: translateX(-4px);
            }

            .brutalist-box {
                border: 2px solid #111;
                box-shadow: 4px 4px 0px #111;
                background: #fff;
                border-radius: 8px;
            }

            .brutalist-article {
                padding: clamp(1.5rem, 5vw, 3rem);
                position: relative;
                overflow: hidden;
            }

            .brutalist-article::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 10px;
                background-color: var(--centro-color);
                border-bottom: 2px solid #111;
            }

            .article-header {
                border-bottom: 2px solid #111;
                padding-bottom: 2rem;
                margin-bottom: 2rem;
                margin-top: 1rem;
            }

            .meta-band {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
                align-items: center;
                margin-bottom: 1.5rem;
            }

            .pub-date {
                font-family: monospace;
                font-weight: bold;
                font-size: 0.8rem;
                background: #111;
                color: #fff;
                padding: 0.2rem 0.6rem;
                display: inline-block;
            }

            .centro-badge {
                font-family: monospace;
                font-weight: bold;
                font-size: 0.8rem;
                background: var(--centro-color);
                color: #fff;
                padding: 0.2rem 0.6rem;
                display: inline-block;
                border: 2px solid #111;
                box-shadow: 2px 2px 0px #111;
                border-radius: 3px;
            }

            .article-header h1 {
                font-family: 'creato', sans-serif;
                font-size: clamp(2rem, 5vw, 3rem);
                text-transform: uppercase;
                line-height: 1.05;
                margin: 0 0 1rem 0;
                color: #111;
            }

            .pub-desc {
                font-family: 'lora', sans-serif;
                font-size: 1.15rem;
                line-height: 1.5;
                color: #444;
                margin: 0;
                font-style: italic;
            }

            .post-hero {
                margin: 2rem 0;
                border: 2px solid #111;
                box-shadow: 4px 4px 0px #111;
                overflow: hidden;
                border-radius: 4px;
                background: #eee;
            }

            .post-hero img {
                width: 100%;
                height: auto;
                display: block;
            }

            .post-content {
                font-size: 1.05rem;
                line-height: 1.7;
                color: #222;
            }

            /* Estilos enriquecidos para el Markdown */
            .post-content :global(p) {
                margin: 0 0 1.5rem 0;
            }

            .post-content :global(h2), .post-content :global(h3) {
                font-family: 'creato', sans-serif;
                text-transform: uppercase;
                color: #111;
                margin: 2rem 0 1rem 0;
            }

            .post-content :global(h2) {
                font-size: 1.6rem;
                border-bottom: 2px solid #111;
                padding-bottom: 0.5rem;
            }

            .post-content :global(ul), .post-content :global(ol) {
                margin: 0 0 1.5rem 0;
                padding-left: 1.5rem;
            }

            .post-content :global(li) {
                margin-bottom: 0.5rem;
            }

            .post-content :global(strong) {
                color: #000;
            }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <a href={`/centros/${pub.data.centro.toLowerCase()}`} class="back-link">
                ← Volver al {centroSigla}
            </a>
            
            <article class="brutalist-article brutalist-box">
                <header class="article-header">
                    <div class="meta-band">
                        <span class="pub-date">
                            {new Date(pub.data.pubDate).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' })}
                        </span>
                        <span class="centro-badge">{centroNombre}</span>
                    </div>
                    <h1>{pub.data.title}</h1>
                    <p class="pub-desc">{pub.data.description}</p>
                </header>

                {pub.data.heroImage && (
                    <div class="post-hero">
                        <img src={pub.data.heroImage.src} alt={pub.data.title} />
                    </div>
                )}

                <div class="post-content">
                    <Content />
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>
