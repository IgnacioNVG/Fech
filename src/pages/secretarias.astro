---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

// Lista de Secretarías FECh
const secretarias = [
    {
        nombre: "Secretaría de Sexualidades y Genero (SESEGEN)",
        encargado: "Blablablabla",
        desc: "Foco en la prevención de la violencia de género, el acompañamiento en denuncias, la promoción de las disidencias y la educación sexual integral.",
        acciones: ["Acompañamiento y Protocolos", "Articulación de Disidencias", "Talleres de Autodefensa y Educación"]
    },
    {
        nombre: "Secretaría de Bienestar y Salud Mental",
        encargado: "[Por definir]",
        desc: "Espacio enfocado en la salud mental comunitaria, la fiscalización de servicios estudiantiles y la defensa de becas y condiciones de alimentación (Junaeb).",
        acciones: ["Salud Mental Comunitaria", "Gestión de Becas y Junaeb", "Calidad de Vida Universitaria"]
    },
    {
        nombre: "Secretaría Académica y de Docencia",
        encargado: "[Por definir]",
        desc: "Defensa de los derechos académicos del estudiantado, análisis de reformas curriculares y mediación en conflictos de docencia y evaluaciones.",
        acciones: ["Defensa ante Sumarios", "Foros Académicos y de Cátedra", "Revisión Curricular Estudiantil"]
    },
    {
        nombre: "Secretaría de Deportes y Recreación",
        encargado: "[Por definir]",
        desc: "Fomento del deporte competitivo y recreativo, la recreación en los campus y la organización de torneos deportivos interfacultades.",
        acciones: ["Torneos Deportivos FECh", "Apoyo a Deportistas UCh", "Vida Saludable e Integración"]
    },
    {
        nombre: "Secretaría de Derechos Humanos",
        encargado: "[Por definir]",
        desc: "Promoción de la memoria histórica, educación en Derechos Humanos y la articulación con comisiones de memoria en campus y organizaciones externas.",
        acciones: ["Memoria Histórica y DDHH", "Cátedra de Formación Crítica", "Solidaridad con Luchas Sociales"]
    },
    {
        nombre: "Secretaría de Medio Ambiente y Sustentabilidad",
        encargado: "[Por definir]",
        desc: "Promoción de campus sustentables, gestión de residuos y compostaje, huertas universitarias comunitarias y debates en torno a la crisis ecológica.",
        acciones: ["Gestión Verde y Reciclaje", "Huertos Urbanos e Intercambio", "Foros de Ecología Política"]
    },
    {
        nombre: "Secretaría de Extensión y Cultura",
        encargado: "[Por definir]",
        desc: "Desarrollo artístico y cultural en los campus, festivales de arte estudiantil, talleres comunitarios abiertos y vinculación social territorial.",
        acciones: ["Talleres Populares Abiertos", "Festivales de Arte y Música", "Redes de Circulación Cultural"]
    }
];
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <BaseHead title={`Secretarías | ${SITE_TITLE}`} description="Secretarías transversales de la Federación de Estudiantes de la Universidad de Chile" />
        <style>
            :global(body) {
                overflow-x: hidden;
            }

            main {
                width: 100%;
                max-width: 1200px;
                margin: 0 auto;
                padding: clamp(2rem, 8vw, 4rem) 5%;
                box-sizing: border-box;
            }

            /* Títulos */
            h2 {
                font-family: 'creato', sans-serif;
                font-size: clamp(2.2rem, 7vw, 4rem);
                text-transform: uppercase;
                line-height: 0.85;
                margin-bottom: 2.5rem;
                color: #000;
            }

            h3 {
                font-family: 'creato', sans-serif;
                font-size: 1.5rem;
                text-transform: uppercase;
                color: #ff0000;
                margin-bottom: 0.5rem;
                line-height: 1.1;
                border-bottom: 2px solid transparent;
                transition: color 0.2s, border-color 0.2s;
            }

            .manifesto-box {
                border-left: 10px solid #000;
                padding: clamp(1.5rem, 4vw, 2rem);
                background: #f4f4f4;
                margin-bottom: 4rem;
                font-family: monospace;
                font-size: 1.1rem;
                border-top: 2px solid #111;
                border-right: 2px solid #111;
                border-bottom: 2px solid #111;
                box-shadow: 4px 4px 0px #111;
                border-radius: 4px;
            }

            .manifesto-box p {
                margin: 0;
            }

            /* Secretarías */
            .commissions-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
                gap: 3rem;
                margin-top: 2rem;
            }

            .commission-card {
                border-top: 4px solid #000;
                padding-top: 1.5rem;
                transition: all 0.3s ease;
            }

            .commission-card:hover {
                border-top-color: #ff0000;
            }

            .commission-card:hover h3 {
                color: #ff0000;
            }

            .commission-card ul {
                list-style: none;
                padding: 0;
                margin-top: 1rem;
            }

            .commission-card li {
                font-size: 0.9rem;
                line-height: 1.4;
                margin-bottom: 0.5rem;
                padding-left: 1.2rem;
                position: relative;
            }

            .commission-card li::before {
                content: "//";
                position: absolute;
                left: 0;
                color: #ff0000;
                font-weight: bold;
            }

            /* Espacios Transversales */
            .transversal-section {
                margin-top: 6rem;
                padding: clamp(1.5rem, 6vw, 4rem);
                background: #ff0000;
                color: #fff;
                border: 2px solid #111;
                box-shadow: 6px 6px 0px #111;
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: clamp(2rem, 5vw, 4rem);
            }

            .transversal-section h2, .transversal-section h3 { color: #fff; }
            .transversal-section h2 { border-bottom: 8px solid #000; margin-bottom: 2rem; }
            .transversal-section p { font-size: 0.95rem; line-height: 1.6; }

            /* Ajustes Mobile específicos */
            @media (max-width: 600px) {
                .transversal-section {
                    padding: 2.5rem 1.5rem;
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <header>
                <h2>Secretarías FECh</h2>
                <div class="manifesto-box">
                    <p>ESPACIOS DE CONSTRUCCIÓN COMUNITARIA: Equipos abiertos y autogestionados para desplegar la organización y resolver las demandas de toda la universidad.</p>
                </div>
            </header>

            <!-- GRILLA DE SECRETARÍAS -->
            <div class="commissions-grid">
                {secretarias.map((sec) => (
                    <div class="commission-card">
                        <h3>{sec.nombre}</h3>
                        <p style="font-weight: bold; color: #555; margin-bottom: 1rem; font-family: monospace; font-size: 0.8rem;">
                            Coordinación: {sec.encargado}
                        </p>
                        <p style="font-size: 0.92rem; line-height: 1.5; color: #444; margin-bottom: 1rem;">
                            {sec.desc}
                        </p>
                        <ul>
                            {sec.acciones.map((acc) => (
                                <li>{acc}</li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>

            <!-- ESPACIOS DE TRABAJO COMPLEMENTARIOS -->
            <section class="transversal-section">
                <div>
                    <h2>Consejo de Presidentes/as (CeP)</h2>
                    <p>Espacio representativo clave que reúne a los centros de estudiantes de cada carrera y facultad de la Universidad de Chile. Tiene un rol normativo y resolutivo fundamental en la conducción política de la federación.</p>
                </div>
                <div>
                    <h2>Comisiones Unitarias</h2>
                    <p>Instancias de articulación de carácter temporal o permanente definidas para enfrentar problemáticas o demandas de contingencia nacional y universitaria específicas (Reforma Universitaria, Financiamiento, etc.).</p>
                </div>
            </section>
        </main>
        <Footer />
    </body>
</html>
