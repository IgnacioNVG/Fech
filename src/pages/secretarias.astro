---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE } from '../consts';

// Lista de Secretarías FECh
const secretarias = [
    {
        nombre: "Secretaría de Sexualidades y Genero (SESEGEN)",
        encargado: "Blablablabla",
        desc: "Foco en la prevención de la violencia de género, el acompañamiento en denuncias, la promoción de las disidencias y la educación sexual integral.",
        acciones: ["Acompañamiento y Protocolos", "Articulación de Disidencias", "Talleres de Autodefensa y Educación"]
    },
    {
        nombre: "Secretaría de Bienestar y Salud Mental",
        encargado: "[Por definir]",
        desc: "Espacio enfocado en la salud mental comunitaria, la fiscalización de servicios estudiantiles y la defensa de becas y condiciones de alimentación (Junaeb).",
        acciones: ["Salud Mental Comunitaria", "Gestión de Becas y Junaeb", "Calidad de Vida Universitaria"]
    },
    {
        nombre: "Secretaría Académica y de Docencia",
        encargado: "[Por definir]",
        desc: "Defensa de los derechos académicos del estudiantado, análisis de reformas curriculares y mediación en conflictos de docencia y evaluaciones.",
        acciones: ["Defensa ante Sumarios", "Foros Académicos y de Cátedra", "Revisión Curricular Estudiantil"]
    },
    {
        nombre: "Secretaría de Deportes y Recreación",
        encargado: "[Por definir]",
        desc: "Fomento del deporte competitivo y recreativo, la recreación en los campus y la organización de torneos deportivos interfacultades.",
        acciones: ["Torneos Deportivos FECh", "Apoyo a Deportistas UCh", "Vida Saludable e Integración"]
    },
    {
        nombre: "Secretaría de Derechos Humanos",
        encargado: "[Por definir]",
        desc: "Promoción de la memoria histórica, educación en Derechos Humanos y la articulación con comisiones de memoria en campus y organizaciones externas.",
        acciones: ["Memoria Histórica y DDHH", "Cátedra de Formación Crítica", "Solidaridad con Luchas Sociales"]
    },
    {
        nombre: "Secretaría de Medio Ambiente y Sustentabilidad",
        encargado: "[Por definir]",
        desc: "Promoción de campus sustentables, gestión de residuos y compostaje, huertas universitarias comunitarias y debates en torno a la crisis ecológica.",
        acciones: ["Gestión Verde y Reciclaje", "Huertos Urbanos e Intercambio", "Foros de Ecología Política"]
    },
    {
        nombre: "Secretaría de Extensión y Cultura",
        encargado: "[Por definir]",
        desc: "Desarrollo artístico y cultural en los campus, festivales de arte estudiantil, talleres comunitarios abiertos y vinculación social territorial.",
        acciones: ["Talleres Populares Abiertos", "Festivales de Arte y Música", "Redes de Circulación Cultural"]
    }
];
---

<Layout title={`Secretarías | ${SITE_TITLE}`}>
    <main>
        <header>
            <span class="subtitle-kicker">Espacios de Trabajo</span>
            <h2>Secretarías FECh</h2>
            <div class="intro-box">
                <p>ESPACIOS DE CONSTRUCCIÓN COMUNITARIA: Equipos abiertos y autogestionados para desplegar la organización y resolver las demandas de toda la universidad.</p>
            </div>
        </header>

        <section>
            <div class="commissions-grid">
                {secretarias.map((sec) => (
                    <div class="commission-card brutalist-box">
                        <span class="commission-meta">Coordinación: {sec.encargado}</span>
                        <h3>{sec.nombre}</h3>
                        <p class="commission-desc">{sec.desc}</p>
                        <ul class="commission-actions">
                            {sec.acciones.map((acc) => (
                                <li>{acc}</li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </section>

        <section class="transversal-section brutalist-box">
            <span class="subtitle-kicker" style="margin-bottom: 1.5rem;">Órganos Complementarios</span>
            
            <div class="transversal-grid">
                <div class="transversal-block">
                    <h4>Consejo de Presidentes/as (CeP)</h4>
                    <p>Espacio representativo clave que reúne a los centros de estudiantes de cada carrera y facultad de la Universidad de Chile. Tiene un rol normativo y resolutivo fundamental en la conducción política de la federación.</p>
                </div>
                <div class="transversal-block">
                    <h4>Comisiones Unitarias</h4>
                    <p>Instancias de articulación de carácter temporal o permanente definidas para enfrentar problemáticas o demandas de contingencia nacional y universitaria específicas (Reforma Universitaria, Financiamiento, etc.).</p>
                </div>
            </div>
        </section>
    </main>

    <style>
        main {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: clamp(2rem, 8vw, 4rem) 5%;
            box-sizing: border-box;
        }

        /* Tipografías base heredadas */
        h2 { font-family: 'creato', sans-serif; font-size: clamp(2.2rem, 7vw, 4rem); text-transform: uppercase; line-height: 0.85; margin-bottom: 2rem; color: #000; }
        h3 { font-family: 'creato', sans-serif; font-size: clamp(1.2rem, 3vw, 1.8rem); text-transform: uppercase; line-height: 1.1; margin-bottom: 0.75rem; color: #000; }
        h4 { font-family: 'lora', sans-serif; font-weight: 800; font-size: 1.2rem; margin: 0 0 0.5rem 0; color: #111; line-height: 1.25; }
        
        /* Componentes compartidos con pleno.astro */
        .subtitle-kicker { font-family: monospace; font-size: 0.85rem; text-transform: uppercase; color: #666; letter-spacing: 0.1em; margin-bottom: 0.5rem; display: block; }
        
        .brutalist-box { border: 2px solid #111; box-shadow: 4px 4px 0px #111; background: #fff; }
        
        .intro-box { border-left: 10px solid #000; padding: clamp(1.5rem, 4vw, 2rem); background: #f4f4f4; margin-bottom: 4rem; font-family: monospace; font-size: 1.1rem; border-top: 2px solid #111; border-right: 2px solid #111; border-bottom: 2px solid #111; box-shadow: 4px 4px 0px #111; border-radius: 4px; }

        /* Grilla de Secretarías */
        .commissions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 2.2rem;
            margin-bottom: 4rem;
        }

        .commission-card {
            border-radius: 8px;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .commission-card:hover {
            transform: translate(-4px, -4px);
            box-shadow: 6px 6px 0px #ff0000;
            border-color: #ff0000;
        }

        .commission-meta {
            font-family: monospace;
            font-size: 0.72rem;
            text-transform: uppercase;
            background: #111;
            color: #fff;
            padding: 0.2rem 0.5rem;
            width: fit-content;
            margin-bottom: 1.2rem;
            border-radius: 2px;
        }

        .commission-desc {
            font-size: 0.95rem;
            line-height: 1.5;
            color: #333;
            margin-bottom: 1.5rem;
            flex-grow: 1;
        }

        .commission-actions {
            list-style: none;
            padding: 0;
            margin: 0;
            border-top: 2px solid #eee;
            padding-top: 1.5rem;
        }

        .commission-actions li {
            font-size: 0.85rem;
            line-height: 1.4;
            margin-bottom: 0.5rem;
            padding-left: 1.2rem;
            position: relative;
            font-family: monospace;
        }

        .commission-actions li::before {
            content: "■";
            position: absolute;
            left: 0;
            color: #ff0000;
            font-size: 0.7rem;
            top: 2px;
        }

        /* Sección Transversal */
        .transversal-section {
            padding: clamp(1.5rem, 4vw, 2.5rem);
            margin-bottom: 4rem;
        }

        .transversal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .transversal-block p {
            font-size: 0.95rem;
            line-height: 1.6;
            color: #333;
            margin: 0;
        }

        @media (max-width: 640px) { 
            .commissions-grid, .transversal-grid { grid-template-columns: 1fr; } 
        }
    </style>
</Layout>